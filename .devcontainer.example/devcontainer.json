{
  "name": "lasuillard/devcontainer-features",
  "image": "mcr.microsoft.com/devcontainers/base:dev-trixie",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "extraNixConfig": "extra-experimental-features = nix-command flakes"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:3": {
      "moby": false
    }
    // To install feature locally, use the following syntax
    // ? There is limitation that resolved path of feature in local must be child of `.devcontainer` folder
    // "./src/kubernetes-tools": {
    //   "install-krew": "latest",
    //   "install-k9s": "latest",
    //   "install-helm": "latest"
    // }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mads-hartmann.bash-ide-vscode",
        "editorconfig.editorconfig",
        "timonwong.shellcheck",
        "mkhl.shfmt"
      ]
    }
  }
}
